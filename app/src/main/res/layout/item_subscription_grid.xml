<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cv_subscription"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp"
    app:strokeColor="#FFE53935">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Half: Colored Header with Large Initial -->
        <FrameLayout
            android:id="@+id/fl_header_bg"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@color/color_74_58_255">

            <!-- Large Initial Letter -->
            <TextView
                android:id="@+id/tv_grid_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="N"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Warning Badge (top right) -->
            <TextView
                android:id="@+id/tv_warning_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:background="@drawable/bg_warning_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="2 hari lagi"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Bottom Half: Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Service Name -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="Netflix"
                android:textColor="@color/color_26_28_28"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Price -->
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Rp 54.000"
                android:textColor="@color/color_74_58_255"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Footer: Category and Date -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <!-- Category Badge -->
                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_badge_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Entertainment"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <!-- Date -->
                <TextView
                    android:id="@+id/tv_next_billing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="18/6/26"
                    android:textColor="@color/color_119_117_136"
                    android:textSize="10sp" />

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
