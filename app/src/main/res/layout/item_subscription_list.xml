<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cv_subscription"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp"
    app:strokeColor="#FFE53935">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Avatar -->
        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_avatar_rounded_square"
            android:gravity="center"
            android:text="N"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title / Service Name -->
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Netflix"
            android:textColor="@color/color_26_28_28"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tv_price"
            app:layout_constraintStart_toEndOf="@+id/tv_avatar"
            app:layout_constraintTop_toTopOf="@+id/tv_avatar" />

        <!-- Category Badge -->
        <TextView
            android:id="@+id/tv_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_badge_pill"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Entertainment"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_name" />

        <!-- Cycle Label -->
        <TextView
            android:id="@+id/tv_cycle_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Bulanan"
            android:textColor="@color/color_119_117_136"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_category"
            app:layout_constraintStart_toEndOf="@+id/tv_category"
            app:layout_constraintTop_toTopOf="@+id/tv_category" />

        <!-- Next Billing Date -->
        <TextView
            android:id="@+id/tv_next_billing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Next billing: 18 Jun 2026"
            android:textColor="@color/color_119_117_136"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_avatar"
            app:layout_constraintEnd_toStartOf="@+id/tv_cycle_suffix"
            app:layout_constraintStart_toStartOf="@+id/tv_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_category" />

        <!-- Price -->
        <TextView
            android:id="@+id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="Rp 54.000"
            android:textColor="@color/color_74_58_255"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_avatar" />

        <!-- Cycle Suffix -->
        <TextView
            android:id="@+id/tv_cycle_suffix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/bln"
            android:textColor="@color/color_119_117_136"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@+id/tv_price"
            app:layout_constraintTop_toBottomOf="@+id/tv_price" />

        <!-- Warning Badge (top right) -->
        <TextView
            android:id="@+id/tv_warning_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_warning_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="2 hari lagi"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
