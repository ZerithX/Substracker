<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Ganti parent ke Theme.MaterialComponents agar kompatibel dengan AppCompatActivity -->
    <style name="Theme.UASAD" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- Use a transparent icon to hide the default icon, so we can transition to our custom SplashFragment seamlessly -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.UASAD</item>
    </style>

    <style name="ShapeAppearance.App.FAB" parent="">
        <item name="cornerFamily">rounded</item> <!-- Can also use 'cut' -->
        <item name="cornerSize">16dp</item>     <!-- Or 50% for a circle/pill -->
    </style>
</resources>